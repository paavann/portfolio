{
    "name": "pavan",
    "private": true,
    "version": "0.0.0",
    "packageManager": "pnpm@10.31.0",
    "scripts": {
        "dev": "pnpm -r --parallel --aggregate-output dev",
        "dev:portfolio": "pnpm --filter @pavan/portfolio dev",
        "dev:api": "pnpm --filter @pavan/api dev",
        "build": "pnpm -r build",
        "lint": "pnpm -r lint",
        "test": "pnpm -r test",
        "typecheck": "pnpm -r --parallel typecheck"
    }
}